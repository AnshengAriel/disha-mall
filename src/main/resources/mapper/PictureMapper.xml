<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ariel.disha.mall.main.mapper.PictureMapper">


    <select id="picturePage" resultType="com.ariel.disha.mall.consts.entity.Picture">
        select * from picture where category_id = #{vo.categoryId} order by create_time desc
    </select>
</mapper>